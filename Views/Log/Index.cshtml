@model LogWebViewer.Models.LogPageModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Log Viewer</title>

    <style>
        body {
            font-family: Arial;
            margin: 20px;
            background: #f5f7fa;
        }

        h1 {
            color: #34495E;
        }

        .box {
            padding: 12px;
            background: #fff;
            border: 1px solid #ccc;
            border-radius: 6px;
            margin-bottom: 15px;
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            background: white;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 8px;
        }

        th {
            background-color: #007ACC;
            color: white;
        }

        tr:nth-child(even) {
            background-color: #f2f2f2;
        }

        .level-ERROR {
            background-color: #fdd;
            color: #900;
        }

        .level-WARN {
            background-color: #ffe;
            color: #aa0;
        }

        .level-INFO {
            background-color: #eef;
            color: #007ACC;
        }

        button {
            background: #007ACC;
            color: white;
            border: none;
            padding: 6px 14px;
            border-radius: 4px;
            cursor: pointer;
        }

            button:hover {
                background: #005fa3;
            }

        .error {
            color: red;
            margin-bottom: 10px;
        }

        .paging a {
            margin: 0 5px;
            text-decoration: none;
        }

        .paging strong {
            margin: 0 5px;
        }
    </style>
</head>

<body>
    <h1>📄 Log Viewer</h1>

    <form asp-action="Upload"
          method="post"
          enctype="multipart/form-data"
          class="box">
        <input type="file" name="logFile" accept=".log" />
        <button type="submit">Upload</button>
    </form>

    @if (ViewBag.Error != null)
    {
        <div class="error">@ViewBag.Error</div>
    }

    <form method="get" asp-action="Page" class="box">
        <input type="hidden" name="page" value="1" />

        <label>
            Level:
            <select name="level">
                <option value="">All</option>
                <option value="ERROR" selected="@(Model.FilterLevel == "ERROR")">ERROR</option>
                <option value="WARN" selected="@(Model.FilterLevel == "WARN")">WARN</option>
                <option value="INFO" selected="@(Model.FilterLevel == "INFO")">INFO</option>
            </select>
        </label>

        <input name="source" value="@Model.FilterSource" placeholder="Source contains…" />
        <input name="function" value="@Model.FilterFunction" placeholder="Function contains…" />

        <button type="submit">Filter</button>
    </form>

    @if (!Model.Logs.Any())
    {
        <div class="box">No logs to display.</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Level</th>
                    <th>Source</th>
                    <th>Function</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs)
                {
                    <tr class="level-@log.Level">
                        <td>@log.Time</td>
                        <td>@log.Level</td>
                        <td>@log.Source</td>
                        <td>@log.Function</td>
                        <td>@log.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (Model.TotalPages > 1)
    {
        <div class="paging box">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                if (i == Model.CurrentPage)
                {
                    <strong>@i</strong>
                }
                else
                {
                    <a asp-action="Page"
                       asp-route-page="@i"
                       asp-route-level="@Model.FilterLevel"
                       asp-route-source="@Model.FilterSource"
                       asp-route-function="@Model.FilterFunction">@i</a>
                }
            }
        </div>
    }

</body>
</html>
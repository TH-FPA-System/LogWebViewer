@model LogWebViewer.Models.LogPageModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Log Viewer</title>
    <style>
        :root {
            --primary: #007ACC;
            --primary-dark: #005fa3;
            --bg: #f5f7fa;
        }
        body { font-family: Arial, sans-serif; margin: 20px; background: var(--bg); }
        h1 { color: #34495E; }
        .card { background: #fff; padding: 12px; border-radius: 6px; border: 1px solid #ddd; margin-bottom: 15px; }
        .flex { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
        button { background: var(--primary); color: #fff; border: none; padding: 6px 14px; border-radius: 4px; cursor: pointer; }
        button:hover { background: var(--primary-dark); }
        button:disabled { opacity: .6; cursor: not-allowed; }
        table { width: 100%; border-collapse: collapse; background: #fff; }
        th, td { border: 1px solid #ddd; padding: 8px; white-space: nowrap; }
        th { background: var(--primary); color: #fff; position: sticky; top: 0; }
        tr:nth-child(even) { background: #f9f9f9; }
        .level-ERROR { background: #fdd; color: #900; }
        .level-WARN { background: #ffe; color: #aa0; }
        .level-INFO { background: #eef; color: #007ACC; }
        .error { color: red; margin-bottom: 10px; }
        .loading { display: none; color: #555; }
        .paging a { margin: 0 4px; text-decoration: none; cursor: pointer; }
        .paging strong { margin: 0 4px; }
        progress { width: 200px; height: 16px; }
    </style>
</head>
<body>

    <h1>📄 Log Viewer</h1>

    <!-- Alert if log file not found -->
    @if (ViewBag.LogNotFound == true)
    {
        <script>
            alert("Log file not found for the specified area and date!");
        </script>
    }

    <!-- Page Loading Indicator -->
    <div id="pageLoading" class="loading">Loading log file…</div>

    <!-- Upload -->
    <div class="card flex">
        <input type="file" id="fileInput" accept=".log">
        <button id="btnUpload" disabled>Upload</button>
        <progress id="progress" value="0" max="100" hidden></progress>
        <span class="loading" id="uploadStatus">Uploading…</span>
    </div>

    <div id="uploadMessage"></div>

    <!-- Filters -->
    <form id="filterForm" method="get" class="card flex">
        <input type="hidden" name="page" value="1" />

        <label>Level:
            <select name="level">
                <option value="" @@(string.IsNullOrEmpty(Model.FilterLevel) ? "selected" : "")>All</option>
                <option value="Error" @@(Model.FilterLevel=="Error"?"selected":"")>Error</option>
                <option value="Warning" @@(Model.FilterLevel=="Warning"?"selected":"")>Warning</option>
                <option value="Info" @@(Model.FilterLevel=="Info"?"selected":"")>Info</option>
                <option value="Debug" @@(Model.FilterLevel=="Debug"?"selected":"")>Debug</option>
            </select>
        </label>

        <label>From: <input type="time" name="fromTime" value="@(Model.FromTime?.ToString("HH:mm") ?? "")" /></label>
        <label>To: <input type="time" name="toTime" value="@(Model.ToTime?.ToString("HH:mm") ?? "")" /></label>
        <label>Description: <input type="text" name="description" value="@(Model.FilterDescription ?? "")" placeholder="Search description…" /></label>

        <button type="submit">Filter</button>
    </form>

    <!-- Table -->
    <div id="logTableContainer">
        @await Html.PartialAsync("_LogTablePartial", Model)
    </div>

    <script>
        const fileInput = document.getElementById('fileInput');
        const btn = document.getElementById('btnUpload');
        const progress = document.getElementById('progress');
        const status = document.getElementById('uploadStatus');
        const uploadMessage = document.getElementById('uploadMessage');
        const tableContainer = document.getElementById('logTableContainer');
        const filterForm = document.getElementById('filterForm');
        const pageLoading = document.getElementById('pageLoading');

        // --- Page loading for URL auto-load ---
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const area = urlParams.get('area');
            const date = urlParams.get('date');
            if (area && date) {
                pageLoading.style.display = 'inline';
                // Hide after short timeout (server already preloaded logs)
                setTimeout(() => pageLoading.style.display = 'none', 500);
            }
        });

        // --- Upload ---
        fileInput.addEventListener('change', () => btn.disabled = !fileInput.files.length);

        btn.addEventListener('click', () => {
            const file = fileInput.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append("logFile", file);

            progress.hidden = false; progress.value = 0;
            status.style.display = 'inline'; uploadMessage.textContent = '';
            btn.disabled = true;

            const xhr = new XMLHttpRequest();
            xhr.open("POST", "/Log/Upload");

            xhr.upload.onprogress = e => {
                if (e.lengthComputable) progress.value = (e.loaded / e.total) * 100;
            };

            xhr.onload = () => {
                btn.disabled = false;
                progress.hidden = true;
                status.style.display = 'none';

                if (xhr.status === 200) {
                    uploadMessage.textContent = "Upload successful!";
                    fetchLogs(1);
                } else {
                    let msg = "Upload failed!";
                    try { msg = JSON.parse(xhr.responseText).message; } catch {}
                    uploadMessage.textContent = msg;
                }
            };

            xhr.onerror = () => {
                btn.disabled = false;
                progress.hidden = true;
                status.style.display = 'none';
                uploadMessage.textContent = "Upload failed (network)";
            };

            xhr.send(formData);
        });

        // --- Filters ---
        filterForm.addEventListener('submit', e => {
            e.preventDefault();
            fetchLogs(1);
        });

        // --- Paging ---
        tableContainer.addEventListener('click', e => {
            if (e.target.tagName === 'A' && e.target.dataset.page) {
                e.preventDefault();
                fetchLogs(e.target.dataset.page);
            }
        });

        // --- Fetch logs (AJAX) ---
        function fetchLogs(page) {
            pageLoading.style.display = 'inline';
            const params = new URLSearchParams(new FormData(filterForm));
            params.set('page', page);

            fetch('/Log/Page?' + params.toString(), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.text())
                .then(html => {
                    tableContainer.innerHTML = html;
                    pageLoading.style.display = 'none';
                })
                .catch(err => {
                    console.warn('Fetch error:', err);
                    pageLoading.style.display = 'none';
                });
        }
    </script>
</body>
</html>
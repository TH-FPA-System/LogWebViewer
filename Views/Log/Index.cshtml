@model LogWebViewer.Models.LogPageModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Log Viewer</title>

    <style>
        :root {
            --primary: #007ACC;
            --primary-dark: #005fa3;
            --bg: #f5f7fa;
        }

        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background: var(--bg);
        }

        h1 {
            color: #34495E;
        }

        .card {
            background: #fff;
            padding: 12px;
            border-radius: 6px;
            border: 1px solid #ddd;
            margin-bottom: 15px;
        }

        .flex {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        button {
            background: var(--primary);
            color: #fff;
            border: none;
            padding: 6px 14px;
            border-radius: 4px;
            cursor: pointer;
        }

            button:hover {
                background: var(--primary-dark);
            }

            button:disabled {
                opacity: .6;
                cursor: not-allowed;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            background: #fff;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 8px;
            white-space: nowrap;
        }

        th {
            background: var(--primary);
            color: #fff;
            position: sticky;
            top: 0;
        }

        tr:nth-child(even) {
            background: #f9f9f9;
        }

        .level-ERROR {
            background: #fdd;
            color: #900;
        }

        .level-WARN {
            background: #ffe;
            color: #aa0;
        }

        .level-INFO {
            background: #eef;
            color: #007ACC;
        }

        .error {
            color: red;
            margin-bottom: 10px;
        }

        .loading {
            display: none;
            color: #555;
        }

        .paging a {
            margin: 0 4px;
            text-decoration: none;
        }

        .paging strong {
            margin: 0 4px;
        }

        progress {
            width: 200px;
            height: 16px;
        }
    </style>
</head>

<body>
    <h1>📄 Log Viewer</h1>

    <!-- Upload -->
    <div class="card flex">
        <input type="file" id="fileInput" accept=".log">
        <button id="btnUpload" disabled>Upload</button>
        <progress id="progress" value="0" max="100" hidden></progress>
        <span class="loading" id="uploadStatus">Uploading…</span>
    </div>

    <div id="uploadMessage"></div>
    <div id="logTableContainer">
        @* This contains your logs table, same as before *@
        @await Html.PartialAsync("_LogTablePartial", Model)
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="error">@ViewBag.Error</div>
    }

    <!-- Filters -->
    <form method="get" asp-action="Page" class="card flex">
        <input type="hidden" name="page" value="1" />

        <label>
            Level:
            <select name="level">
                <option value="">All</option>
                <option value="ERROR" selected="@(Model.FilterLevel == "ERROR")">ERROR</option>
                <option value="WARN" selected="@(Model.FilterLevel == "WARN")">WARN</option>
                <option value="INFO" selected="@(Model.FilterLevel == "INFO")">INFO</option>
            </select>
        </label>

        <input name="source" value="@Model.FilterSource" placeholder="Source contains…" />
        <input name="function" value="@Model.FilterFunction" placeholder="Function contains…" />

        <button type="submit">Filter</button>
    </form>

    <!-- Table -->
    @if (!Model.Logs.Any())
    {
        <div class="card">No logs found.</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Level</th>
                    <th>Source</th>
                    <th>Function</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs)
                {
                    <tr class="level-@log.Level">
                        <td>@log.Time</td>
                        <td>@log.Level</td>
                        <td>@log.Source</td>
                        <td>@log.Function</td>
                        <td>@log.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <!-- Paging -->
    @if (Model.TotalPages > 1)
    {
        <div class="paging card">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                if (i == Model.CurrentPage)
                {
                    <strong>@i</strong>
                }
                else
                {
                    <a asp-action="Page"
                       asp-route-page="@i"
                       asp-route-level="@Model.FilterLevel"
                       asp-route-source="@Model.FilterSource"
                       asp-route-function="@Model.FilterFunction">@i</a>
                }
            }
        </div>
    }

    <script>
               const fileInput = document.getElementById('fileInput');
        const btn = document.getElementById('btnUpload');
        const progress = document.getElementById('progress');
        const status = document.getElementById('uploadStatus');
        const uploadMessage = document.getElementById('uploadMessage');
        const tableContainer = document.getElementById('logTableContainer');

        fileInput.addEventListener('change', () => {
            btn.disabled = !fileInput.files.length;
        });

        btn.addEventListener('click', () => {
            const file = fileInput.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append("logFile", file);

            // Show progress and status
            progress.hidden = false;
            progress.value = 0;
            status.style.display = 'inline';
            uploadMessage.textContent = '';
            btn.disabled = true;

            const xhr = new XMLHttpRequest();
            xhr.open("POST", "/Log/Upload");

            xhr.upload.onprogress = e => {
                if (e.lengthComputable) {
                    progress.value = (e.loaded / e.total) * 100;
                }
            };

            xhr.onload = () => {
                btn.disabled = false;
                progress.hidden = true;
                status.style.display = 'none';

                if (xhr.status === 200) {
                    uploadMessage.textContent = "Upload successful!";
                    // Reload the log table dynamically
                    fetch('/Log/Table')
                        .then(r => r.text())
                        .then(html => tableContainer.innerHTML = html);
                } else {
                    uploadMessage.textContent = "Upload failed!";
                }
            };

            xhr.onerror = () => {
                btn.disabled = false;
                progress.hidden = true;
                status.style.display = 'none';
                uploadMessage.textContent = "Upload failed (network error)!";
            };

            xhr.send(formData);
        });
    </script>

</body>
</html>
@model LogWebViewer.Models.LogPageModel

@if (Model.Logs == null || !Model.Logs.Any())
{
    <div class="card"><em>No log entries found.</em></div>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Time</th>
                <th>Level</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.Logs)
            {
                <tr>
                    <!-- Time column: show '-' if empty/null, otherwise trimmed -->
                    <td>@(string.IsNullOrWhiteSpace(log.Time) ? "-" : log.Time.Trim())</td>
                    <!-- Level column colored -->
                    <td class="level-@log.Level.ToUpper()">@log.Level</td>
                    <td>@log.Description</td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <div class="paging card flex">
            @{
                int current = Model.CurrentPage;
                int total = Model.TotalPages;
            }

            @if (current > 1)
            {
                <a href="#" data-page="@(current - 1)">Prev</a>
            }

            @for (int i = 1; i <= total; i++)
            {
                if (i == current)
                {
                    <strong>@i</strong>
                }
                else
                {
                    <a href="#" data-page="@i">@i</a>
                }
            }

            @if (current < total)
            {
                <a href="#" data-page="@(current + 1)">Next</a>
            }
        </div>
    }
}